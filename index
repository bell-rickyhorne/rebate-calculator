<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Rebate Calculator</title>
  <style>
    :root {
      --bg: #f8fafc;
      --card: #ffffff;
      --text: #0f172a;
      --muted: #64748b;
      --border: #e2e8f0;
      --soft: #f1f5f9;
      --accent: #0f172a;
      --amber-bg: #fffbeb;
      --amber-border: #fde68a;
      --green-bg: #ecfdf5;
      --green-border: #a7f3d0;
      --shadow: 0 10px 30px rgba(15, 23, 42, 0.08);
      --radius: 18px;
    }

    * { box-sizing: border-box; }
    body {
      margin: 0;
      font-family: Arial, Helvetica, sans-serif;
      background: linear-gradient(to bottom, #f8fafc, #ffffff);
      color: var(--text);
    }

input[type="number"].lamp-price {
  background: #fff4cc;
  border: 1px solid #facc15;

}

input[type="number"].fitting-price {
  background: #d9fbe7;
  border: 1px solid #22c55e;
}

/* Lamp calculated outputs */
.summary-item.lamp-output {
  background: #fff4cc;
  border: 1px solid #facc15;
}

/* Fitting calculated outputs */
.summary-item.fitting-output {
  background: #d9fbe7;
  border: 1px solid #22c55e;
}

    .container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 24px;
    }

    .hero, .card {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 24px;
      box-shadow: var(--shadow);
    }

    .hero {
      padding: 24px;
      display: grid;
      gap: 16px;
      grid-template-columns: 1.4fr 0.8fr;
      align-items: start;
    }

    .badge-row {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
      margin-bottom: 12px;
    }

    .badge {
      display: inline-block;
      padding: 6px 12px;
      border-radius: 999px;
      font-size: 12px;
      border: 1px solid var(--border);
      background: white;
    }

    .badge.dark {
      background: var(--accent);
      color: white;
      border-color: var(--accent);
    }

    h1, h2, h3, p { margin: 0; }
    h1 { font-size: 36px; margin-bottom: 12px; }
    h2 { font-size: 22px; margin-bottom: 8px; }
    p.subtle { color: var(--muted); line-height: 1.5; }

    .feature-list {
      display: grid;
      gap: 14px;
    }

    .feature {
      display: flex;
      gap: 12px;
      align-items: flex-start;
      padding: 12px;
      background: var(--soft);
      border-radius: 16px;
    }

    .feature-icon {
      width: 40px;
      height: 40px;
      display: grid;
      place-items: center;
      border-radius: 12px;
      background: white;
      border: 1px solid var(--border);
      font-weight: bold;
    }

    .tabs {
      display: flex;
      gap: 8px;
      margin: 24px 0 18px;
    }

    .tab-btn {
      border: 1px solid var(--border);
      background: white;
      color: var(--text);
      padding: 12px 18px;
      border-radius: 14px;
      cursor: pointer;
      font-size: 14px;
      font-weight: bold;
    }

    .tab-btn.active {
      background: var(--accent);
      color: white;
      border-color: var(--accent);
    }

    .metrics {
      display: grid;
      gap: 16px;
      grid-template-columns: repeat(4, 1fr);
      margin-bottom: 18px;
    }

    .metric {
      padding: 18px;
    }

    .metric-label {
      color: var(--muted);
      font-size: 14px;
      margin-bottom: 10px;
    }

    .metric-value {
      font-size: 28px;
      font-weight: bold;
      margin-bottom: 6px;
      border-radius: 14px;
      padding: 12px 14px;
      border: 1px solid transparent;
    }

    .metric-value.amber {
      background: var(--amber-bg);
      border-color: var(--amber-border);
    }

    .metric-value.green {
      background: var(--green-bg);
      border-color: var(--green-border);
    }

    .metric-note {
      color: var(--muted);
      font-size: 12px;
    }

    .main-grid {
      display: grid;
      grid-template-columns: 1.15fr 0.85fr;
      gap: 18px;
    }

    .section {
      padding: 22px;
    }

    .header-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      margin-bottom: 18px;
    }

    .grid-header, .grid-row {
      display: grid;
      grid-template-columns: 1.4fr 1fr 1fr;
      gap: 10px;
      align-items: center;
    }

    .grid-header {
      background: var(--soft);
      border-radius: 14px;
      padding: 12px 14px;
      font-size: 13px;
      font-weight: bold;
      color: var(--muted);
      margin-bottom: 10px;
    }

    .grid-row {
      margin-bottom: 10px;
    }

    .label-cell {
      border: 1px solid var(--border);
      background: white;
      border-radius: 14px;
      padding: 12px 14px;
      font-weight: bold;
    }

    input[type="number"] {
      width: 100%;
      padding: 12px 38px 12px 12px;
      border-radius: 14px;
      border: 1px solid var(--border);
      font-size: 14px;
      text-align: right;
      background: white;
    }

    .input-wrap {
      position: relative;
    }

    .suffix {
      position: absolute;
      right: 12px;
      top: 50%;
      transform: translateY(-50%);
      color: var(--muted);
      font-size: 13px;
      pointer-events: none;
    }

    .readonly {
      border-radius: 14px;
      padding: 12px 14px;
      text-align: right;
      font-weight: bold;
      border: 1px solid var(--border);
      background: var(--soft);
    }

    .readonly.amber {
      background: var(--amber-bg);
      border-color: var(--amber-border);
    }

    .readonly.green {
      background: var(--green-bg);
      border-color: var(--green-border);
    }

    .summary-item {
      display: flex;
      justify-content: space-between;
      gap: 12px;
      border: 1px solid var(--border);
      border-radius: 14px;
      padding: 14px;
      margin-bottom: 10px;
      background: white;
    }

    .two-col {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 14px;
      margin-bottom: 18px;
    }

    .field label {
      display: block;
      font-size: 14px;
      font-weight: bold;
      margin-bottom: 8px;
    }

    .totals-row {
      margin-top: 8px;
    }

    .totals-label {
      background: var(--accent);
      color: white;
      border-radius: 14px;
      padding: 12px 14px;
      font-weight: bold;
    }

    .actions {
      display: flex;
      justify-content: flex-end;
      margin-top: 18px;
    }

    button.reset-btn {
      border: 1px solid var(--border);
      background: white;
      padding: 12px 16px;
      border-radius: 14px;
      cursor: pointer;
      font-weight: bold;
    }

    .small-note {
      margin-top: 20px;
      color: var(--muted);
      font-size: 13px;
      line-height: 1.5;
    }

    @media (max-width: 1000px) {
      .hero, .main-grid, .metrics {
        grid-template-columns: 1fr;
      }
    }

    @media (max-width: 700px) {
      .two-col { grid-template-columns: 1fr; }
      .grid-header, .grid-row {
        grid-template-columns: 1fr;
      }
      h1 { font-size: 28px; }
    }
  </style>
</head>
<body>
  <div class="container">
    <section class="hero">
      <div>
        <div class="badge-row">
          <span class="badge dark">Bell Lighting</span>
          <span class="badge">Standalone HTML</span>
          <span class="badge">Front-end only</span>
        </div>
        <h1>Rebate Calculator</h1>
        <p class="subtle">
          This is a single-file HTML version of your calculator. Users can edit only the input fields on the page, while totals and outputs are calculated automatically and shown as read-only values.
        </p>
      </div>
      <div class="feature-list">
        <div class="feature"><div class="feature-icon">£</div><div><strong>Editable inputs only</strong><br><span class="subtle">Screen prices and rebate percentages can be changed.</span></div></div>
        <div class="feature"><div class="feature-icon">#</div><div><strong>Read-only outputs</strong><br><span class="subtle">Net net, totals, rebate values, and spend outputs cannot be typed into.</span></div></div>
        <div class="feature"><div class="feature-icon">!</div><div><strong>No Excel save flow</strong><br><span class="subtle">This is a webpage, not an Excel workbook.</span></div></div>
      </div>
    </section>

    <div class="tabs">
      <button class="tab-btn active" data-tab="b1">B1</button>
      <button class="tab-btn" data-tab="others">Others</button>
    </div>

    <div id="app"></div>

    <p class="small-note">
      Note: because this is front-end only, the calculation logic is visible in the page source to anyone technical enough to inspect it.
    </p>
  </div>

  <script>
    const b1Rows = ["National", "Regional", "EELine/ACEL", "Buy In", "Settlement", "Local", "Online Ordering", "UKLD"];
    const otherRows = ["National", "Promo/Discount", "Settlement", "Online Ordering", "Other"];

    const defaults = {
      b1: {
        title: "B1",
        rows: b1Rows,
        lampScreenPrice: 50,
        fittingScreenPrice: 100,
        lampPercentages: {
          "National": "",
          "Regional": "",
          "EELine/ACEL": "",
          "Buy In": "",
          "Settlement": "",
          "Local": "",
          "Online Ordering": "",
          "UKLD": ""
        },
        fittingPercentages: {
          "National": "",
          "Regional": "",
          "EELine/ACEL": "",
          "Buy In": "",
          "Settlement": "",
          "Local": "",
          "Online Ordering": "",
          "UKLD": ""
        }
      },
      others: {
        title: "Others",
        rows: otherRows,
        lampScreenPrice: 3.09,
        fittingScreenPrice: 55.4,
        lampPercentages: {
          "National": "",
          "Promo/Discount": "",
          "Settlement": "",
          "Online Ordering": "",
          "Other": ""
        },
        fittingPercentages: {
          "National": "",
          "Promo/Discount": "",
          "Settlement": "",
          "Online Ordering": "",
          "Other": ""
        }
      }
    };

    let state = JSON.parse(JSON.stringify(defaults));
    let activeTab = 'b1';

    function currency(value) {
      return new Intl.NumberFormat('en-GB', {
        style: 'currency',
        currency: 'GBP',
        minimumFractionDigits: 2,
        maximumFractionDigits: 2
      }).format(value || 0);
    }

    function percent(value) {
      return ((value || 0) * 100).toFixed(1) + '%';
    }

    function inputValue(v) {
      return v === null || v === undefined ? '' : v;
    }

    function calculate(section) {
      const rows = section.rows;
      const lampTotal = rows.reduce((sum, row) => sum + (Number(section.lampPercentages[row]) || 0) / 100, 0);
      const fittingTotal = rows.reduce((sum, row) => sum + (Number(section.fittingPercentages[row]) || 0) / 100, 0);
      const lampRebate = section.lampScreenPrice * lampTotal;
      const fittingRebate = section.fittingScreenPrice * fittingTotal;

      return {
        lampTotal,
        fittingTotal,
        lampRebate,
        fittingRebate,
        lampNetNet: section.lampScreenPrice - lampRebate,
        fittingNetNet: section.fittingScreenPrice - fittingRebate,
        lampSpend5k: 5000 * lampTotal,
        lampSpend10k: 10000 * lampTotal,
        lampSpend25k: 25000 * lampTotal,
        fittingSpend10k: 10000 * fittingTotal,
        fittingSpend50k: 50000 * fittingTotal,
        fittingSpend100k: 100000 * fittingTotal
      };
    }

function inputField(value, path, suffix, step = '0.5', extraClass = '') {
  return `
    <div class="input-wrap">
      <input class="${extraClass}" type="number" step="${step}" min="0" value="${inputValue(value)}" data-path="${path}">
      <span class="suffix">${suffix}</span>
    </div>
  `;
}

    function render() {
      const section = state[activeTab];
      const totals = calculate(section);
      const app = document.getElementById('app');

      app.innerHTML = `
        <section class="metrics">
          <div class="card metric">
            <div class="metric-label">Lamp net net</div>
            <div class="metric-value amber">${currency(totals.lampNetNet)}</div>
            <div class="metric-note">Read only</div>
          </div>
          <div class="card metric">
            <div class="metric-label">Fitting net net</div>
            <div class="metric-value green">${currency(totals.fittingNetNet)}</div>
            <div class="metric-note">Read only</div>
          </div>
          <div class="card metric">
            <div class="metric-label">Lamp rebate</div>
            <div class="metric-value">${currency(totals.lampRebate)}</div>
            <div class="metric-note">Calculated automatically</div>
          </div>
          <div class="card metric">
            <div class="metric-label">Fitting rebate</div>
            <div class="metric-value">${currency(totals.fittingRebate)}</div>
            <div class="metric-note">Calculated automatically</div>
          </div>
        </section>

        <section class="main-grid">
          <div class="card section">
            <div class="header-row">
              <div>
                <h2>${section.title} calculator</h2>
                <p class="subtle">Change only the values below. Outputs update instantly.</p>
              </div>
              <span class="badge dark">Read-only outputs</span>
            </div>

            <div class="two-col">
              <div class="field">
                <label>Lamp screen price</label>
                ${inputField(section.lampScreenPrice, activeTab + '.lampScreenPrice', '£', '0.5', 'lamp-price')}
              </div>
              <div class="field">
                <label>Fitting screen price</label>
                ${inputField(section.fittingScreenPrice, activeTab + '.fittingScreenPrice', '£', '0.5', 'fitting-price')}
              </div>
            </div>

            <div class="grid-header">
              <div>Category</div>
              <div style="text-align:right;">Lamp %</div>
              <div style="text-align:right;">Fitting %</div>
            </div>

            ${section.rows.map(row => `
              <div class="grid-row">
                <div class="label-cell">${row}</div>
                ${inputField(section.lampPercentages[row], activeTab + '.lampPercentages.' + row, '%', '0.5')}
                ${inputField(section.fittingPercentages[row], activeTab + '.fittingPercentages.' + row, '%', '0.5')}
              </div>
            `).join('')}

            <div class="grid-row totals-row">
              <div class="totals-label">Totals</div>
              <div class="readonly amber">${percent(totals.lampTotal)}</div>
              <div class="readonly green">${percent(totals.fittingTotal)}</div>
            </div>
          </div>

          <div>
            <div class="card section" style="margin-bottom:18px;">
              <h2>Calculated outputs</h2>
              <p class="subtle" style="margin-bottom:14px;">These values are displayed only and cannot be typed into.</p>
              <div class="summary-item lamp-output"><span>Lamp £5k spend</span><strong>${currency(totals.lampSpend5k)}</strong></div>
              <div class="summary-item lamp-output"><span>Lamp £10k spend</span><strong>${currency(totals.lampSpend10k)}</strong></div>
              <div class="summary-item lamp-output"><span>Lamp £25k spend</span><strong>${currency(totals.lampSpend25k)}</strong></div>
              <div class="summary-item fitting-output"><span>Fitting £10k spend</span><strong>${currency(totals.fittingSpend10k)}</strong></div>
              <div class="summary-item fitting-output"><span>Fitting £50k spend</span><strong>${currency(totals.fittingSpend50k)}</strong></div>
              <div class="summary-item fitting-output"><span>Fitting £100k spend</span><strong>${currency(totals.fittingSpend100k)}</strong></div>
            </div>

            <div class="card section">
              <h2>Page behaviour</h2>
              <div class="summary-item"><span>Export buttons</span><strong>None shown</strong></div>
              <div class="summary-item"><span>Excel Save / Save As</span><strong>Not applicable</strong></div>
            </div>
          </div>
        </section>

        <div class="actions">
          <button class="reset-btn" id="resetBtn">Reset ${section.title} values</button>
        </div>
      `;

      bindInputs();
      document.getElementById('resetBtn').addEventListener('click', () => {
        state[activeTab] = JSON.parse(JSON.stringify(defaults[activeTab]));
        render();
      });
    }

    function setByPath(obj, path, value) {
      const parts = path.split('.');
      let current = obj;
      for (let i = 0; i < parts.length - 1; i++) {
        current = current[parts[i]];
      }
      current[parts[parts.length - 1]] = value;
    }

    function bindInputs() {
				document.querySelectorAll('input[data-path]').forEach(input => {
    input.addEventListener('change', (e) => {
      const raw = e.target.value;
      if (raw === '') {
        setByPath(state, e.target.dataset.path, '');
      } else {
        const numeric = Math.round(parseFloat(raw) * 100) / 100;
        setByPath(state, e.target.dataset.path, Number.isFinite(numeric) ? numeric : '');
      }
      render();
    });
  });
}

    document.querySelectorAll('.tab-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.tab-btn').forEach(x => x.classList.remove('active'));
        btn.classList.add('active');
        activeTab = btn.dataset.tab;
        render();
      });
    });

    render();
  </script>
</body>
</html>
